          <Layout class="org.netbeans.modules.form.compat2.layouts.support.JScrollPaneSupportLayout"/>
          <SubComponents>
            <Component class="javax.swing.JTextArea" name="texto">
              <Properties>
                <Property name="columns" type="int" value="20"/>
                <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
                  <Font name="Serif" size="18" style="0"/>
                </Property>
                <Property name="lineWrap" type="boolean" value="true"/>
                <Property name="rows" type="int" value="5"/>
                <Property name="text" type="java.lang.String" value="Esta plataforma ha sido dise&#xf1;ada para optimizar los procesos internos de la empresa, permitiendo un control eficiente del inventario, registro de ventas y organizaci&#xf3;n de productos. A trav&#xe9;s de este sistema, el personal podr&#xe1; acceder de manera r&#xe1;pida y segura a la informaci&#xf3;n necesaria para el desarrollo de sus actividades diarias.&#xa;&#xa;Stop Jeans se ha consolidado como una empresa comprometida con la calidad, la organizaci&#xf3;n y la mejora continua, ofreciendo productos que responden a las tendencias del mercado y a las necesidades de sus clientes. Este sistema representa un paso hacia la transformaci&#xf3;n digital de la empresa, facilitando la toma de decisiones y mejorando la eficiencia operativa.&#xa;&#xa;Se recomienda a los usuarios hacer un uso adecuado de la plataforma, mantener actualizada la informaci&#xf3;n y seguir los procedimientos establecidos para garantizar un correcto funcionamiento del sistema."/>
                <Property name="wrapStyleWord" type="boolean" value="true"/>
                <Property name="border" type="javax.swing.border.Border" editor="org.netbeans.modules.form.editors2.BorderEditor">
                  <Border info="null"/>
                </Property>
              </Properties>
            </Component>
          </SubComponents>
